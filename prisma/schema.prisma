// Mondzorgwerkt — multi-tenant datamodel.
// Domeinregels staan in src/domain; dit schema is de opslagvorm.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- identiteit ----------

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  isPlatformAdmin Boolean   @default(false)
  createdAt       DateTime  @default(now())

  memberships      Membership[]
  candidateProfile CandidateProfile?
  applications     Application[]
  invitations      Invitation[]
  auditLogs        AuditLog[]
}

// ---------- praktijkorganisaties (tenants) ----------

enum OrgStatus {
  active
  suspended
  archived
}

model Organization {
  id                String     @id @default(cuid())
  name              String
  slug              String     @unique
  status            OrgStatus  @default(active)
  // bedrijfsgegevens
  kvkNumber         String?
  billingEmail      String?
  acquisitionSource String?
  activatedAt       DateTime? // practice_activated is eenmalig
  onboardingState   Json? // autosave van de commerciële onboarding
  // Publicatie-consent voor de openbare praktijkpagina (/praktijken/[slug]):
  // zonder expliciete toestemming bestaat de praktijk publiek niet. Het
  // moment van toestemming wordt vastgelegd voor de audittrail.
  publicConsent     Boolean    @default(false)
  publicConsentAt   DateTime?
  // Publieke omschrijving zoals getoond op de praktijkpagina (optioneel).
  publicDescription String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @default(now()) @updatedAt
  archivedAt        DateTime?

  locations       PracticeLocation[]
  memberships     Membership[]
  vacancies       Vacancy[]
  subscriptions   Subscription[]
  billingCustomer BillingCustomer?
  usageEvents     UsageEvent[]
  auditLogs       AuditLog[]
}

model PracticeLocation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  street         String?
  houseNumber    String?
  city           String
  postcode       String
  latitude       Float
  longitude      Float
  phone          String?
  treatmentRooms Int      @default(1)
  // gestructureerde praktijkkenmerken (taxonomiesleutels)
  traits             String[] @default([])
  equipment          String[] @default([])
  software           String[] @default([])
  specializations    String[] @default([])
  patientPopulation  String[] @default([])
  // gewenste minimale bezetting per dagdeel: { ma: { ochtend: 2, … }, … }
  staffingTarget Json?
  createdAt      DateTime @default(now())

  vacancies   Vacancy[]
  teamMembers TeamMember[]

  @@index([organizationId])
}

enum MemberRole {
  owner
  admin
  recruiter
  hiring_manager
  viewer
  billing_manager
}

enum MembershipStatus {
  active
  invited
  revoked
}

model Membership {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  role           MemberRole
  status         MembershipStatus @default(active)
  // locatiegebonden rechten: leeg = alle locaties van de organisatie
  locationIds    String[]         @default([])
  createdAt      DateTime         @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ---------- kandidaten ----------

enum CandidateStatus {
  draft
  active
  paused
  archived
}

enum ProfileVisibility {
  visible    // naam zichtbaar voor praktijken met match
  anonymous  // alleen geanonimiseerd profiel tot kandidaat toestemming geeft
  hidden     // onvindbaar; alleen zelf solliciteren
}

model CandidateProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  role            String // taxonomie: tandarts, mondhygienist, …
  experienceLevel String // starter | medior | senior
  postcode        String
  latitude        Float
  longitude       Float
  maxTravelMinutes Int   @default(30)

  hoursMin      Int
  hoursMax      Int
  contractTypes String[] @default([]) // loondienst, zzp, …
  availableFrom DateTime?
  salaryMin     Int? // eurocenten p/m bij loondienst
  salaryMax     Int?
  revenueShareMin Int? // gewenst omzetpercentage (%) bij zzp — behandelaren werken met een deel van de omzet, niet met uurtarief

  // beschikbaarheid per weekdag+dagdeel: { ma: { ochtend: "preferred" | "available" | "unavailable", … }, … }
  availability Json

  equipmentExperience    String[] @default([])
  equipmentWantsToWork   String[] @default([])
  techniquesWantsToLearn String[] @default([])
  softwareSkills         String[] @default([])
  specializations        String[] @default([])
  treatmentInterests     String[] @default([])
  preferredPopulation    String[] @default([])

  mentorshipNeeded      Boolean  @default(false)
  developmentGoals      String[] @default([])
  preferredPracticeSize String? // klein | middel | groot | geen_voorkeur
  workPace              String? // rustig | gemiddeld | hoog | geen_voorkeur
  teamPreferences       String[] @default([])

  visibility        ProfileVisibility @default(anonymous)
  anonymitySettings Json?
  completenessScore Int               @default(0)
  status            CandidateStatus   @default(draft)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, role])
  // Retentie: inactieve draft-profielen op leeftijd (src/server/privacy.ts).
  @@index([status, updatedAt])
}

// ---------- vacatures ----------

enum VacancyStatus {
  draft
  published
  paused
  filled
  expired
}

model Vacancy {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  locationId     String
  location       PracticeLocation @relation(fields: [locationId], references: [id])

  title           String
  slug            String?       @unique // publieke, stabiele identifier (fase 8)
  role            String
  description     String?
  experienceLevel String? // minimaal gewenst niveau

  // werkdagen/dagdelen: { ma: { ochtend: "required" | "preferred" | null, … }, … }
  schedule Json

  hoursMin      Int
  hoursMax      Int
  contractTypes String[] @default([])
  startBy       DateTime?
  startByHard   Boolean  @default(false)
  salaryMin     Int?
  salaryMax     Int?
  revenueShareMax Int? // maximaal geboden omzetpercentage (%) bij zzp

  // criteria met niveau: { registrations: {…}, equipment: {…}, … }
  // per criterium: { values: string[], level: "required" | "preferred" | "informational" }
  criteria Json

  culture       String[] @default([]) // praktijkcultuur-taxonomie
  mentorship    Boolean  @default(false)
  development   String[] @default([]) // ontwikkelmogelijkheden
  flexibilityNote String?

  status      VacancyStatus @default(draft)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  applications Application[]
  invitations  Invitation[]
  snapshots    MatchSnapshot[]

  @@index([organizationId, status])
  @@index([status, role])
  // Publieke vacaturelijst: status published, gesorteerd op publishedAt desc
  // (src/server/public/queries.ts).
  @@index([status, publishedAt])
}

// ---------- match-vastlegging ----------

enum SnapshotContext {
  match_view
  invitation
  application
  simulation
}

model MatchSnapshot {
  id              String          @id @default(cuid())
  vacancyId       String
  vacancy         Vacancy         @relation(fields: [vacancyId], references: [id])
  candidateUserId String
  context         SnapshotContext
  score           Int
  label           String
  algorithmVersion String
  result          Json // volledige MatchResult
  profileData     Json // bepalende profielgegevens op dat moment
  vacancyData     Json // bepalende vacaturegegevens op dat moment
  createdAt       DateTime        @default(now())

  applications Application[]
  invitations  Invitation[]

  @@index([vacancyId, candidateUserId])
}

enum ApplicationStatus {
  submitted
  in_review
  interview
  offered
  hired
  rejected
  withdrawn
}

model Application {
  id              String            @id @default(cuid())
  vacancyId       String
  vacancy         Vacancy           @relation(fields: [vacancyId], references: [id])
  candidateUserId String
  candidate       User              @relation(fields: [candidateUserId], references: [id])
  status          ApplicationStatus @default(submitted)
  motivation      String?
  matchSnapshotId String?
  matchSnapshot   MatchSnapshot?    @relation(fields: [matchSnapshotId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([vacancyId, candidateUserId])
  @@index([candidateUserId])
}

enum InvitationStatus {
  sent
  accepted
  declined
  expired
}

model Invitation {
  id              String           @id @default(cuid())
  vacancyId       String
  vacancy         Vacancy          @relation(fields: [vacancyId], references: [id])
  candidateUserId String
  candidate       User             @relation(fields: [candidateUserId], references: [id])
  status          InvitationStatus @default(sent)
  message         String?
  matchSnapshotId String?
  matchSnapshot   MatchSnapshot?   @relation(fields: [matchSnapshotId], references: [id])
  createdAt       DateTime         @default(now())
  // Uiterste geldigheid; na dit moment kan de uitnodiging niet meer worden
  // geaccepteerd (afgedwongen in respondToInvitation).
  expiresAt       DateTime?

  @@unique([vacancyId, candidateUserId])
  @@index([candidateUserId])
}

// ---------- commerciële laag ----------

model Plan {
  id       String        @id @default(cuid())
  code     String        @unique // trial | essential | growth | multi_location
  name     String
  active   Boolean       @default(true)
  versions PlanVersion[]
}

model PlanVersion {
  id                String        @id @default(cuid())
  planId            String
  plan              Plan          @relation(fields: [planId], references: [id])
  version           Int
  priceMonthlyCents Int
  priceYearlyCents  Int
  currency          String        @default("EUR")
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())

  entitlements  Entitlement[]
  subscriptions Subscription[]

  @@unique([planId, version])
}

model Entitlement {
  id            String      @id @default(cuid())
  planVersionId String
  planVersion   PlanVersion @relation(fields: [planVersionId], references: [id])
  key           String // bv. max_locations, max_active_vacancies, talent_radar, …
  enabled       Boolean     @default(true)
  limitInt      Int? // null = onbeperkt (indien enabled)
  meta          Json?

  @@unique([planVersionId, key])
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  planVersionId  String
  planVersion    PlanVersion        @relation(fields: [planVersionId], references: [id])
  status         SubscriptionStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  trialEndsAt        DateTime?
  // geplande wijziging (bv. downgrade per periode-einde) en coulance na failed payment
  scheduledPlanVersionId String?
  scheduledChangeAt      DateTime?
  graceUntil             DateTime?
  // Tijdstip (bij de provider) van het laatst verwerkte betaalstatus-event.
  // Voorkomt dat een ouder, later aankomend webhook-event een nieuwere
  // status terugdraait (out-of-order-bescherming).
  lastBillingEventAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  items SubscriptionItem[]

  @@index([organizationId, status])
  // Cron applyScheduledChanges: niet-canceled abonnementen op periode-einde
  // (src/lib/billing/index.ts).
  @@index([status, currentPeriodEnd])
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  key            String // extra_location | recruiter_seat | invite_pack | …
  quantity       Int          @default(1)

  @@unique([subscriptionId, key])
}

model UsageEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  key            String // bv. candidate_invite
  quantity       Int          @default(1)
  idempotencyKey String       @unique
  createdAt      DateTime     @default(now())

  @@index([organizationId, key, createdAt])
}

model BillingCustomer {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id])
  provider           String // local_test | stripe
  providerCustomerId String
  meta               Json?

  @@unique([provider, providerCustomerId])
}

// ---------- analytics, audit, configuratie ----------

model AnalyticsEvent {
  id                String   @id @default(cuid())
  name              String // stabiele eventnaam uit src/domain/analytics
  organizationId    String?
  locationId        String?
  userId            String?
  candidateId       String? // pseudoniem (cuid van profiel, geen naam/e-mail)
  plan              String?
  acquisitionSource String?
  context           Json?
  createdAt         DateTime @default(now())

  @@index([name, createdAt])
  @@index([organizationId, createdAt])
  // Retentie (24 mnd) en 30-dagen-gebruiksvensters (src/server/kpi.ts).
  @@index([createdAt])
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  action         String // bv. vacancy.publish, subscription.upgrade
  entity         String
  entityId       String
  meta           Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
}

model MatchingConfigVersion {
  id        String   @id @default(cuid())
  version   String   @unique // semver, gelijk aan algorithmVersion in code
  config    Json
  createdAt DateTime @default(now())
}

// ---------- commerciële beta: pipeline, gesprekken, consent ----------

// Volledige statushistorie van een kandidaat-vacaturetraject, met de
// verantwoordelijke actor. De actuele stand leeft op Invitation/Application;
// dit is het onwijzigbare journaal.
model PipelineStatusChange {
  id              String   @id @default(cuid())
  vacancyId       String
  candidateUserId String
  fromStatus      String?
  toStatus        String // matched|invited|interested|applied|interview_scheduled|offer|hired|declined|rejected|withdrawn
  actorType       String // practice | candidate | system
  actorUserId     String?
  reasonCode      String?
  note            String?
  createdAt       DateTime @default(now())

  @@index([vacancyId, candidateUserId, createdAt])
}

enum InterviewStatus {
  proposed
  confirmed
  declined
  cancelled
}

// Gespreksplanning: praktijk stelt momenten voor, kandidaat kiest er één.
model Interview {
  id               String          @id @default(cuid())
  vacancyId        String
  candidateUserId  String
  status           InterviewStatus @default(proposed)
  slots            Json // voorgestelde momenten: [{ startsAt: ISO, durationMinutes }]
  chosenSlot       DateTime?
  proposedByUserId String
  message          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([vacancyId, candidateUserId])
  @@index([candidateUserId, status])
}

// Expliciete toestemming van een kandidaat om naam + contactgegevens te
// delen met één organisatie (optioneel per vacature). Zonder rij: anoniem.
model CandidateConsent {
  id              String    @id @default(cuid())
  candidateUserId String
  organizationId  String
  vacancyId       String?
  scope           String    @default("contact_details")
  grantedAt       DateTime  @default(now())
  revokedAt       DateTime?

  @@unique([candidateUserId, organizationId, vacancyId, scope])
  @@index([organizationId])
}

// Gestructureerde reden bij belangrijke beslissingen (data-moat). Verandert
// nooit automatisch individuele scores.
model MatchDecisionFeedback {
  id              String   @id @default(cuid())
  matchSnapshotId String?
  vacancyId       String
  candidateUserId String?
  organizationId  String?
  actorType       String // practice | candidate
  decision        String // declined | rejected | withdrawn | cancelled | other
  reasonCode      String // dagen|reisafstand|uren|salaris_tarief|ervaring|apparatuur|specialisatie|cultuur|niet_beschikbaar|vacature_gewijzigd|anders
  note            String? @db.VarChar(500)
  createdAt       DateTime @default(now())

  @@index([vacancyId])
  @@index([reasonCode, createdAt])
}

// ---------- notificaties ----------

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // stabiele sleutel, bv. invitation_received
  title     String
  body      String
  href      String?
  readAt    DateTime?
  dedupeKey String    @unique // voorkomt dubbele meldingen (idempotent)
  meta      Json?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  // Retentie (6 mnd): opruimen op leeftijd (src/server/privacy.ts).
  @@index([createdAt])
}

model NotificationPreference {
  id      String  @id @default(cuid())
  userId  String
  type    String // notificatietype of "all"
  inApp   Boolean @default(true)
  email   Boolean @default(true)

  @@unique([userId, type])
}

// Development-outbox voor e-mail zolang er geen productieprovider is.
model OutboxEmail {
  id             String    @id @default(cuid())
  toEmail        String
  subject        String
  body           String
  notificationId String?
  status         String    @default("pending") // pending | sent | failed
  createdAt      DateTime  @default(now())
  sentAt         DateTime?

  @@index([status, createdAt])
}

// ---------- bezettingsplanning ----------

// Huidig teamlid van een locatie (geen platformgebruiker): naam, functie en
// vaste werkdagen, met tijdelijke afwezigheid.
model TeamMember {
  id          String    @id @default(cuid())
  locationId  String
  location    PracticeLocation @relation(fields: [locationId], references: [id])
  name        String
  role        String // taxonomie-functie
  schedule    Json // vaste werkdagen: { ma: { ochtend: true, … }, … }
  contractHours Int? // contracturen per week
  employmentType String? // loondienst | zzp | detachering
  startDate   DateTime? // toekomstige start
  endDate     DateTime? // verwachte uitstroom/einde
  absentFrom  DateTime?
  absentUntil DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  absences TeamAbsence[]

  @@index([locationId])
}

// ---------- Workstream A: schaalfase ----------

// Verzuim en verlof van teamleden, getypeerd (fase 2).
model TeamAbsence {
  id           String   @id @default(cuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id])
  kind         String // verlof | ziekte | zwangerschapsverlof | anders
  from         DateTime
  until        DateTime?
  note         String?
  createdAt    DateTime @default(now())

  @@index([teamMemberId, from])
}

// Immutable capaciteitsscenario: simulatie tot een bevoegde gebruiker bevestigt (fase 2).
model StaffingScenario {
  id              String   @id @default(cuid())
  organizationId  String
  locationId      String
  name            String
  kind            String // uitval | extra_kamer | nieuwe_locatie | vertrek | structurele_dag | parttime_combinatie | tijdelijk | multi_locatie
  input           Json
  result          Json
  status          String   @default("simulatie") // simulatie | bevestigd | verworpen
  createdByUserId String
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([organizationId, createdAt])
}

// Account health-momentopname, uitlegbaar en geversioneerd (fase 5).
model AccountHealthSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  status         String // healthy | attention | at_risk | onboarding_incomplete
  score          Int
  reasons        Json
  version        String
  calculatedAt   DateTime @default(now())

  @@index([organizationId, calculatedAt])
}

// Cache voor privacyveilige marktinzichten (fase 6).
model MarketInsightSnapshot {
  id         String   @id @default(cuid())
  view       String // regionaal | functie | schaarste_per_dag | flexibiliteit | trend
  dimensionKey String // bv. "mondhygienist:utrecht"
  period     String // bv. "2026-07"
  data       Json
  sampleSize Int
  createdAt  DateTime @default(now())

  @@unique([view, dimensionKey, period])
}

// Schaduwscore van matching v2 naast de actieve versie (fase 7).
model ShadowMatchScore {
  id              String   @id @default(cuid())
  vacancyId       String
  candidateUserId String
  baseVersion     String
  shadowVersion   String
  baseScore       Int
  shadowScore     Int
  baseEligible    Boolean
  shadowEligible  Boolean
  diff            Json // verklaarde verschillen per categorie
  createdAt       DateTime @default(now())

  @@index([shadowVersion, createdAt])
  @@index([vacancyId, candidateUserId])
}

// API-sleutels per organisatie (fase 9).
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  prefix         String    @unique // publiek deel, bv. mzw_live_ab12
  hashedKey      String // sha256 van de volledige sleutel
  scopes         String[]  @default([])
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([organizationId])
}

model WebhookSubscription {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  secret         String // voor HMAC-signing
  events         String[] @default([])
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id])
  event          String
  payload        Json
  idempotencyKey String   @unique
  status         String   @default("pending") // pending | delivered | failed | dead
  attempts       Int      @default(0)
  lastError      String?
  nextAttemptAt  DateTime?
  createdAt      DateTime @default(now())
  deliveredAt    DateTime?

  @@index([status, nextAttemptAt])
}

model ExportJob {
  id             String    @id @default(cuid())
  organizationId String
  kind           String // vacatures | pipeline | bezetting | analytics
  params         Json?
  status         String    @default("pending") // pending | running | done | failed
  resultPath     String?
  requestedByUserId String
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([organizationId, createdAt])
}

// AVG-verzoeken: inzage/export/verwijdering (fase 10).
model PrivacyRequest {
  id          String    @id @default(cuid())
  userId      String
  kind        String // export | verwijdering | correctie
  status      String    @default("open") // open | afgerond | geweigerd
  note        String?
  requestedAt DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, requestedAt])
}

// Vaste-venster rate limiting over serverless-instanties heen (fase 10).
model RateLimitCounter {
  key         String // bv. "login:1.2.3.4" of "api:mzw_live_ab12"
  windowStart DateTime
  count       Int      @default(1)

  @@id([key, windowStart])
  // Retentie (7 dgn): verlopen vensters over álle keys heen opruimen.
  @@index([windowStart])
}

// Idempotente verwerking van inkomende provider-webhooks (fase 4).
model InboundWebhookEvent {
  id         String   @id @default(cuid())
  provider   String // stripe | local_test
  externalId String
  type       String
  payload    Json
  status     String   @default("verwerkt") // verwerkt | genegeerd | fout
  createdAt  DateTime @default(now())

  @@unique([provider, externalId])
}
