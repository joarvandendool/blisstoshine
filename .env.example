# Kopieer naar .env en vul in. Secrets horen nooit in de repository.

# PostgreSQL-connectiestring. Lokaal: de dev-database.
# Productie (Vercel + Supabase-integratie): gebruik POSTGRES_PRISMA_URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mondzorgwerkt"

# Aparte database voor integratietests (wordt door Vitest gebruikt).
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mondzorgwerkt_test"

# Minimaal 32 tekens; ondertekent sessiecookies.
SESSION_SECRET="vervang-dit-door-een-lange-willekeurige-string"

# dev | test | production — scheidt configuratie per omgeving.
APP_ENV="dev"
