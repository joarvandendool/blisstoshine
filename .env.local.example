# Supabase — vul deze uit Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key (alleen server-side, NOOIT in client gebruiken)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin-pincode voor /admin reset/correctie (4-6 cijfers)
ADMIN_PIN=1234

# QR-code doel op /display
NEXT_PUBLIC_QR_TARGET_URL=https://blisstoshine.nl/steun-ons/herinneringen/

# Doelbedrag in centen (1000000 = €10.000)
NEXT_PUBLIC_GOAL_CENTS=1000000

# --- Branding ---
# Officieel logo (laat leeg om de versie op blisstoshine.nl te gebruiken,
# of zet op /logo.png als je het bestand in public/ plaatst)
NEXT_PUBLIC_LOGO_URL=https://blisstoshine.nl/wp-content/uploads/bliss_to_shine_logo.png

# --- Sfeervideo (YouTube) ---
NEXT_PUBLIC_VIDEO_ID=BTbwXCihGQc

# --- Instagram ---
# Handle voor de "volg ons" QR-code
NEXT_PUBLIC_IG_HANDLE=blisstoshine
# Live volgers + posts via de Instagram Graph API (Business-account gekoppeld
# aan een Facebook-pagina). Leeg laten = scherm toont alleen een volg-ons QR.
IG_USER_ID=
IG_ACCESS_TOKEN=
